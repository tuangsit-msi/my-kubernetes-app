# 1. เลือก Base Image ที่เป็นทางการและมีขนาดเล็ก (แนะนำตระกูล alpine)
FROM nginx:stable-alpine

# 2. คัดลอกซอร์สโค้ดจากเครื่องเราเข้าไปยัง Image
# ตัวอย่าง: คัดลอกไฟล์ทั้งหมดในโฟลเดอร์ปัจจุบันไปไว้ที่โฟลเดอร์เว็บของ Nginx
COPY . /usr/share/nginx/html

# 3. กำหนดให้คอนเทนเนอร์ทำงานด้วย user ที่ไม่ใช่ root เพื่อความปลอดภัย
# (หมายเหตุ: สำหรับ nginx-alpine มักจะมี user 'nginx' เตรียมไว้ให้แล้ว)
USER nginx

# 4. ระบุพอร์ตที่แอปจะเปิดใช้งาน
EXPOSE 80

# 5. กำหนดคำสั่งที่จะรันเมื่อคอนเทนเนอร์เริ่มทำงาน
CMD ["nginx", "-g", "daemon off;"]